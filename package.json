{
  "name": "@koddsson/accessibility-scanner",
  "version": "0.0.0-dev",
  "description": "An accessibility scanner",
  "type": "module",
  "module": "./dist/src/scanner.js",
  "main": "./dist/src/scanner.js",
  "exports": {
    ".": "./dist/src/scanner.js",
    "./rules/*": "./dist/src/rules/*.js"
  },
  "repository": {
    "url": "git+https://github.com/koddsson/accessibility-scanner.git"
  },
  "scripts": {
    "build": "tsc",
    "lint:types": "tsc --noEmit",
    "lint": "npm run lint:types && eslint src/**/*.ts",
    "format": "npm run lint -- --fix",
    "test": "npm run format && web-test-runner",
    "test:watch": "npm run format && web-test-runner --watch",
    "start": "web-dev-server",
    "build:readme": "tsx generate-readme.ts",
    "sync:testcases": "tsx scripts/sync-act-testcases.ts"
  },
  "files": [
    "dist/src/*"
  ],
  "keywords": [],
  "author": "Kristján Oddsson",
  "license": "MIT",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@koddsson/eslint-config": "^4.0.0",
    "@open-wc/testing": "^4.0.0",
    "@types/mocha": "^10.0.10",
    "@web/dev-server": "^1.0.0",
    "@web/dev-server-esbuild": "^2.0.0",
    "@web/test-runner": "^1.0.0",
    "@web/test-runner-junit-reporter": "^1.0.0",
    "@web/test-runner-playwright": "^1.0.0",
    "bottleneck": "^2.19.5",
    "eslint": "^10.0.3",
    "tablemark": "^4.1.0",
    "tsx": "^4.15.4",
    "typescript": "^6.0.2"
  }
}
